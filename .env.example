# PostgreSQL
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DB=

# pgAdmin
PGADMIN_DEFAULT_EMAIL=
PGADMIN_DEFAULT_PASSWORD=

# Airflow (Linux: run `id -u`)
AIRFLOW_UID=

# Airflow Fernet key
# Generate with:
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AIRFLOW__CORE__FERNET_KEY=

# Airflow metadata DB URL (must match POSTGRES_USER/PASSWORD/DB)
AIRFLOW__DATABASE__SQL_ALCHEMY_CONN=

# Airflow webserver/scheduler shared secret (required for log reading)
# Generate with:
# python -c "import base64, os; print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
AIRFLOW__WEBSERVER__SECRET_KEY=

# Airflow logs
AIRFLOW__CORE__BASE_LOG_FOLDER=
AIRFLOW__LOGGING__BASE_LOG_FOLDER=

# GCP project settings
GCP_PROJECT_ID=
GCS_BUCKET_NAME=

# Path of GCP key inside Airflow container (do not change)
GOOGLE_APPLICATION_CREDENTIALS=

# Path of GCP key inside Airflow container for ingestion scripts
GCS_KEY_PATH=

# Path of credentials inside Spark container
GCP_KEY_PATH=